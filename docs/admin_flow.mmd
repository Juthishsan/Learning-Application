graph TD
    linkStyle default stroke:#000000,stroke-width:4px;
    classDef default fill:#ffffff,stroke:#000000,stroke-width:4px,color:#000000,font-size:18px,font-weight:bold;
    classDef startEnd fill:#ffffff,stroke:#000000,stroke-width:5px,color:#000000,rx:30,ry:30,font-size:20px,font-weight:bold;
    classDef decision fill:#ffffff,stroke:#000000,stroke-width:4px,color:#000000,font-size:18px,font-weight:bold;

    Start((Start)):::startEnd --> Visit[Visit Learning Portal]
    Visit --> Login[Login via Secure Authentication]
    Login --> CheckRole{Role ==<br/>Admin?}:::decision
    
    CheckRole -- No --> Deny[Access Denied] --> End2((End)):::startEnd
    CheckRole -- Yes --> Dash[Access Admin Control Panel]
    
    Dash --> Path1[User Management]
    Dash --> Path2[System Analytics]
    Dash --> Path3[Support & Governance]

    Path1 --> ViewU[View Registered Users List]
    ViewU --> Filter[Filter by Student / Instructor]
    Filter --> MonitorReq[Monitor Enrollment Statuses]

    Path2 --> ViewRev[Review Total Enrollments & Revenue]
    ViewRev --> Metrics[Review Course Popularity Metrics]

    Path3 --> Inbox[Access Contact / Support Inbox]
    Inbox --> Query[Review Submitted User Queries]
    Query --> Resolve[Respond to / Resolve Tickets]

    MonitorReq --> Log[View Platform Activity Logs]
    Metrics --> Log
    Resolve --> Log
    Log --> End((End)):::startEnd
