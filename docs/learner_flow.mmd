graph TD
    linkStyle default stroke:#000000,stroke-width:4px;
    classDef default fill:#ffffff,stroke:#000000,stroke-width:4px,color:#000000,font-size:18px,font-weight:bold;
    classDef startEnd fill:#ffffff,stroke:#000000,stroke-width:5px,color:#000000,rx:30,ry:30,font-size:20px,font-weight:bold;
    classDef decision fill:#ffffff,stroke:#000000,stroke-width:4px,color:#000000,font-size:18px,font-weight:bold;
    classDef process fill:#ffffff,stroke:#000000,stroke-width:4px,color:#000000,font-size:18px,font-weight:bold;

    Start((Start)):::startEnd --> Visit[Visit Learning Portal]
    Visit --> Reg{Already<br/>Registered?}:::decision
    
    Reg -- Yes --> Login[Login via Secure Authentication]
    Reg -- No --> Signup[Sign Up / Register Account]
    Signup --> Pref[Set Personalization Preferences<br/>Field, Occupation, Skills]
    Pref --> Dash[Access Learner Dashboard]
    Login --> Dash

    Dash --> Sub1[Learning Path]:::process
    Dash --> Sub2[Assessment Path]:::process
    Dash --> Sub3[Enrollment Path]:::process

    Sub1 --> ViewE[View Enrolled Courses]
    ViewE --> SelC[Select Course to Learn]
    SelC --> ActiveC[Access Course Content Sidebar]
    ActiveC --> Type{Content<br/>Type?}:::decision
    Type -- Video --> Watch[Watch Lecture via Player]
    Watch --> Trans[Read AI-Generated Transcript]
    Trans --> NLP[Use NLP Smart Search]
    Type -- PDF/Doc --> Read[Read/Download Study Material]
    NLP --> Mark[Mark Content as Complete]
    Read --> Mark

    Sub2 --> Dead[View Upcoming Deadlines]
    Dead --> TakeQ[Take AI-Generated Quiz]
    TakeQ --> SubmitQ[Submit & Receive Instant Score]
    SubmitQ --> PassCheck{Score >=<br/>80%?}:::decision
    PassCheck -- Yes --> Passed[Quiz Marked as Passed<br/>Update Course Progress]
    PassCheck -- No --> Failed[Review Incorrect Answers<br/>Retake Assessment]

    Sub3 --> Browse[Browse Course Catalog]
    Browse --> AddC[Add New Course to Cart]
    AddC --> Checkout[Secure Checkout / Payment]
    Checkout --> Notify[Receive Enrollment Notification]

    Mark --> End((End)):::startEnd
    Passed --> End
    Failed --> End
    Notify --> End
